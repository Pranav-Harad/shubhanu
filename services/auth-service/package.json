{
  "name": "shubhanu-auth-service",
  "version": "1.0.0",
  "private": true,
  "description": "Auth Microservice for Shubhanu - Handles Parent Registration and JWT Login validation",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
